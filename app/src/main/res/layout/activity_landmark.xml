<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Image Container Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_dark"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp">

                    <ImageView
                        android:id="@+id/landmark_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@color/primary"
                        android:contentDescription="Landmark photo"/>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <!-- Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background_premium"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/landmark_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/landmark_xp_badge"
                        android:layout_marginEnd="12dp"
                        android:text="Landmark Name"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <!-- XP badge pill -->
                    <LinearLayout
                        android:id="@+id/landmark_xp_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/xp_badge_gradient"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/xp_amount_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+100"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XP"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"/>

                    </LinearLayout>

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3C64"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/landmark_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description text goes here..."
                    android:textColor="#CCCCCC"
                    android:textSize="15sp"
                    android:lineSpacingExtra="5dp"/>

            </LinearLayout>

            <!-- Proximity & GPS Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background_premium"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS CAPTURE RADAR"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/distance_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Distance"
                            android:textColor="@color/grey"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/distance_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- m"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Capture Radius"
                            android:textColor="@color/grey"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/radius_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100 m"
                            android:textColor="@color/accent"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3C64"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Radar / Landmark Status -->
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking your location..."
                    android:textColor="@color/gold"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Conquest Button -->
            <Button
                android:id="@+id/conquest_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/button_background"
                android:text="Capture this place"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:elevation="4dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- XP Popup Overlay (centered over whole screen) -->
    <FrameLayout
        android:id="@+id/xp_popup_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/xp_popup"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/xp_popup_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="52sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/xp_popup_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+100 XP"
                android:textColor="#FFD700"
                android:textSize="40sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Landmark Conquered!"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Keep exploring 🌍"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>