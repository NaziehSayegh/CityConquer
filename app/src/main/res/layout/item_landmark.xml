<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_bg"
    android:layout_marginBottom="6dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/landmark_status_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerVertical="true"
        android:text="🔒"
        android:textSize="24sp"
        android:gravity="center"/>

    <TextView
        android:id="@+id/landmark_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/landmark_status_icon"
        android:layout_marginStart="12dp"
        android:text="Landmark Name"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/landmark_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/landmark_name"
        android:layout_toEndOf="@id/landmark_status_icon"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="Description"
        android:textColor="@color/grey"
        android:textSize="13sp"/>

    <TextView
        android:id="@+id/landmark_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/landmark_description"
        android:layout_toEndOf="@id/landmark_status_icon"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="🔒 Not conquered"
        android:textColor="@color/grey"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/landmark_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="+100 XP"
        android:textColor="@color/gold"
        android:textSize="14sp"
        android:textStyle="bold"/>

</RelativeLayout>