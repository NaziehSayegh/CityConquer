<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:background="@drawable/friend_card_bg"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <!-- Colored left status bar -->
    <View
        android:id="@+id/status_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:minHeight="72dp"
        android:background="#555555"/>

    <!-- Lock / Check icon -->
    <TextView
        android:id="@+id/landmark_status_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:gravity="center"
        android:text="🔒"
        android:textSize="22sp"
        android:background="@drawable/avatar_bg"/>

    <!-- Text section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/landmark_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Landmark Name"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/landmark_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Description"
            android:textColor="#888888"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/landmark_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Not conquered"
            android:textColor="#777777"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- XP badge on the right -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:background="@drawable/xp_badge_gradient"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/landmark_xp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+100"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XP"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"/>

    </LinearLayout>

</LinearLayout>