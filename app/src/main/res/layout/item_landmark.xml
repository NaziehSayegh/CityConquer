<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#16213E"
    android:layout_marginBottom="4dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/landmark_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Landmark Name"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/landmark_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:text="+100 XP"
        android:textColor="#FFD700"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/landmark_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/landmark_name"
        android:layout_marginTop="4dp"
        android:text="Description"
        android:textColor="#AAAAAA"
        android:textSize="13sp"/>

    <TextView
        android:id="@+id/landmark_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/landmark_description"
        android:layout_marginTop="8dp"
        android:text="🔒 Not conquered"
        android:textColor="#888888"
        android:textSize="13sp"/>

</RelativeLayout>